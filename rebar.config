{cover_export_enabled, true}.

{deps, [
  {metal, "0.1.2"}
]}.

{dialyzer, [
  {plt_extra_apps, []},
  %% Foil generates `foil_modules` (and `<namespace>_foil`) at runtime via
  %% foil_compiler:load/2, so dialyzer can't statically see them. Suppress
  %% the resulting "unknown function" class without hiding real bugs.
  {warnings, [no_unknown]}
]}.

{ex_doc, [
  {api_reference, true},
  {extras, ["README.md", "CHANGELOG.md", "LICENSE"]},
  {main, "readme"},
  {prefix_ref_vsn_with_v, false},
  {source_url, "https://github.com/lpgauth/foil"}
]}.

{erl_opts, [
  debug_info
]}.

{plugins, [rebar3_hex, rebar3_ex_doc]}.

{hex, [
  {doc, #{provider => ex_doc}}
]}.

{profiles, [
  {compile, [
    {erl_opts, [
      warnings_as_errors,
      warn_export_all,
      warn_export_vars,
      warn_missing_spec,
      warn_obsolete_guard,
      warn_shadow_vars,
      warn_untyped_record,
      warn_unused_import,
      warn_unused_vars
    ]}
  ]},
  {test, [
    {deps, [
      {timing,
        {git, "https://github.com/lpgauth/timing.git", {tag, "0.1.3"}}}
    ]}
  ]}
]}.

{xref_checks, [
  deprecated_functions,
  deprecated_function_calls,
  locals_not_used,
  undefined_function_calls
]}.
